{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "WebWorker"],
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "functions/**/*.ts",
    "functions/**/*.d.ts"
  ]
}
